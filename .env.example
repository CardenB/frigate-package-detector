# Copy to .env and fill in. .env is gitignored.

# Free key from https://app.roboflow.com/settings/api — needed for
# scripts/download_roboflow.py. Leave blank to skip Roboflow sources.
ROBOFLOW_API_KEY=

# Build target: "multi" (COCO classes + package) or "single" (package only).
BUILD_MODE=multi

# Where FiftyOne stores its downloaded zoo datasets (COCO / Open Images can be
# large; point this at a roomy disk). Optional.
# FIFTYONE_DATASET_ZOO_DIR=/mnt/data/fiftyone

# Split fractions for build_dataset.py (optional overrides).
# VAL_FRAC=0.1
# TEST_FRAC=0.05
# SPLIT_SEED=0

# Remote open-vocab "locate-anything" (LocateAnything VLM) service for
# scripts/eval_remote.py (LAN, no auth). Leave blank to skip the remote benchmark.
REMOTE_DETECTOR_URL=          # e.g. http://10.0.0.10:8002
# REMOTE_DETECTOR_ROUTE=/locate
# REMOTE_DETECTOR_MODE=hybrid          # fast | slow | hybrid
# REMOTE_DETECTOR_TIMEOUT=60

# Frigate instance for the review flywheel (scripts/frigate_pull.py).
# Deployment-private — LAN URL of your Frigate, e.g. http://10.0.0.5:5000
FRIGATE_URL=
# Optional bearer token if your Frigate requires auth.
# FRIGATE_API_KEY=
